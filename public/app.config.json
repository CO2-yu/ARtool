{
  "schemaVersion": 1,
  "app": {
    "title": "AR Product Viewer",
    "logoText": "AR",
    "maxActiveMarkers": 3,
    "lostTimeoutMs": 800,
    "targetFps": 24,
    "packagesIndex": "packages/index.json",
    "ar": {
      "sourceWidth": 1280,
      "sourceHeight": 720,
      "canvasWidth": 960,
      "canvasHeight": 720,
      "maxDetectionRate": 45,
      "patternRatio": 0.5,
      "labelingMode": "black_region",
      "thresholdMode": "auto_otsu"
    }
  },
  "ui": {
    "cameraMessage": "カメラを許可してください",
    "markerMessage": "マーカーをカメラに映してください",
    "loadingMessage": "読み込み中",
    "errorMessage": "表示できませんでした"
  }
}
