{
  "schemaVersion": 1,
  "id": "simple_test",
  "name": "Simple Test Marker",
  "description": "Simple high-contrast marker and large blue cube for AR recognition testing.",
  "model": {
    "path": "model.gltf",
    "format": "gltf"
  },
  "marker": {
    "id": "simple_test_marker",
    "path": "marker.patt",
    "image": "marker.png",
    "type": "pattern",
    "physicalSizeMm": 100
  },
  "transform": {
    "position": [0, 0, 0],
    "rotation": [0, 0, 0],
    "scale": [1, 1, 1]
  },
  "scale": {
    "default": 0.083333,
    "min": 0.02,
    "max": 1.0,
    "step": 0.01,
    "presets": {
      "miniature": {
        "label": "1/12",
        "value": 0.083333
      },
      "real": {
        "label": "Real",
        "value": 1.0
      }
    }
  },
  "animation": {
    "autoPlay": true,
    "defaultClip": null
  },
  "ui": {
    "showScaleControls": false,
    "thumbnail": "marker.png",
    "enablePinchScale": true,
    "showScaleSlider": true
  }
}
